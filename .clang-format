---
Language: Cpp
BasedOnStyle: LLVM

# Tabs for indentation, spaces for alignment (e.g. line continuations)
UseTab: ForIndentation
TabWidth: 2
IndentWidth: 2

# Const always on the right (e.g., int const* not const int*)
QualifierAlignment: Right

# One space inside parentheses: ( x ) not (x)
SpacesInParentheses: true

# Braces: same line for if/for/while, separate line for functions and classes
BreakBeforeBraces: Custom
BraceWrapping:
  AfterClass: true
  AfterStruct: true
  AfterFunction: true
  AfterNamespace: true
  AfterEnum: true
  AfterControlStatement: Never

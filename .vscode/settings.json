{
  "cmake.buildDirectory": "${workspaceFolder}/build_${variant:buildType}",
  "cmake.buildTask": true,
  "cmake.defaultLaunchTarget": "neural_implementation",
  "cmake.ctest.testExplorerIntegrationEnabled": true,
  "code-runner.executorMap": {
    "cpp": "cd $workspaceRoot && ninja -C build_debug && ./build_debug/neural_implementation"
  },
  "code-runner.runInTerminal": true,
  "code-runner.fileDirectoryAsCwd": false
}

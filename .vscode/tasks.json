{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "CMake: build (preset release)",
			"type": "shell",
			"command": "cmake --build --preset release",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "Build debug",
			"type": "shell",
			"command": "cmake --build --preset debug",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "CMake: build (preset relwithdebinfo)",
			"type": "shell",
			"command": "cmake --build --preset relwithdebinfo",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {}
			},
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "CMake: configure + build (preset relwithdebinfo)",
			"type": "shell",
			"command": "cmake --preset relwithdebinfo && cmake --build --preset relwithdebinfo",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"problemMatcher": [
				"$gcc"
			]
		}
	]
}
